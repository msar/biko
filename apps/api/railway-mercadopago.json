{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npx prisma generate --schema apps/api/prisma/schema.prisma"
  },
  "deploy": {
    "startCommand": "npm run sync:mercadopago --workspace @biko/api",
    "cronSchedule": "0 10 * * *",
    "restartPolicyType": "NEVER"
  }
}
