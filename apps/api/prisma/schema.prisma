generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum PaymentMethodType {
  DEBIT_CARD
  CREDIT_CARD
  WALLET // ej: MODO, MercadoPago
  CASH
  BANK_TRANSFER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum CardNetwork {
  VISA
  MASTERCARD
  AMEX
  CABAL
  NONE // billeteras, efectivo, transferencia
}

enum EntityKind {
  BANK
  WALLET
  OTHER
}

enum PromotionSource {
  MANUAL
  SCRAPED
}

enum DiscountKind {
  PERCENTAGE_REFUND
  INSTALLMENTS
  FIXED_AMOUNT
  OTHER
}

enum StatementImportStatus {
  PENDING
  PROCESSED
  FAILED
}

enum StatementImportLineStatus {
  PENDING
  NEW
  MERGED
  SKIPPED
}

enum StatementAmountResolution {
  KEEP_EXISTING
  USE_STATEMENT
}

enum ExpenseScope {
  HOUSEHOLD
  PERSONAL
}

enum SplitMode {
  EQUAL
  ASSIGN
  AMOUNT
  SHARES
  PERCENTAGE
}

enum RecurringAmountType {
  FIXED
  VARIABLE
}

enum RecurringCadence {
  MONTHLY
}

enum RecurringOccurrenceStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum NotificationType {
  RECURRING_REMINDER
  RECURRING_DUE
  RECURRING_AUTO_CREATED
}

// ============================================================
// CATÁLOGO GLOBAL DE ENTIDADES Y MEDIOS DE PAGO (seed, no editable por hogar)
// ============================================================

// Banco o billetera: "Santander", "BBVA", "Galicia", "MODO", "Naranja X",
// "MercadoPago". Global y seedeado para evitar entradas manuales tipo
// "Visa Sant" / "Santander visa" que rompen el matching de promociones.
model Entity {
  id   String     @id @default(cuid())
  name String     @unique
  kind EntityKind

  definitions PaymentMethodDefinition[]
  promotions  Promotion[]
  capUsages   MonthlyCapUsage[]
}

// Combinación estándar entidad + tipo + red: "Santander Visa (crédito)",
// "Santander Amex (crédito)", "MODO", "Efectivo". Los hogares eligen de esta
// lista, nunca tipean el nombre del banco.
model PaymentMethodDefinition {
  id       String            @id @default(cuid())
  // null solo para definiciones sin entidad (Efectivo, Transferencia genérica)
  entityId String?
  entity   Entity?           @relation(fields: [entityId], references: [id])
  name     String            // nombre de display: "Santander Visa (crédito)"
  type     PaymentMethodType
  network  CardNetwork       @default(NONE)
  active   Boolean           @default(true)

  paymentMethods PaymentMethod[]

  @@unique([entityId, type, network])
}

// ============================================================
// HOGAR Y USUARIOS
// ============================================================

model Household {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique @default(cuid())
  // Provincia del hogar para filtrar promos regionales (null = ver todas).
  province   String?
  createdAt  DateTime @default(now())
  // Backfill único de favoritos desde historial de compras con promo.
  favoritePromosSyncedAt DateTime?
  // Alta única de medios de pago por defecto (Efectivo, Transferencia).
  defaultMethodsAddedAt DateTime?

  users            User[]
  categories       Category[]
  paymentMethods   PaymentMethod[]
  purchases        Purchase[]
  statementImports StatementImport[]
  monthlyCapUsages MonthlyCapUsage[]
  hiddenWeeklyPromos HouseholdHiddenWeeklyPromo[]
  favoriteWeeklyPromos HouseholdFavoriteWeeklyPromo[]
  recurringPayments RecurringPayment[]
  notifications    Notification[]
}

model User {
  id           String   @id @default(cuid())
  householdId  String
  household    Household @relation(fields: [householdId], references: [id])
  name         String
  email        String    @unique
  // Null si el usuario se autentica vía un provider externo (ej. Clerk) en vez de password propio.
  passwordHash String?
  // "password" hoy; "clerk" / "google" el día que se migre a un provider externo.
  authProvider String    @default("password")
  // Id del usuario en el provider externo, cuando authProvider != "password".
  externalId   String?   @unique
  createdAt    DateTime  @default(now())

  purchases    Purchase[]
  paidPurchases Purchase[] @relation("PurchasePayer")
  ownedMethods PaymentMethod[] @relation("MethodOwner")
  allocations  PurchaseAllocation[]
  recurringPayments RecurringPayment[] @relation("RecurringCreator")
  amountHistories RecurringAmountHistory[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]
  statementImports StatementImport[]
}

// Comercios/promos que el hogar ocultó en Mi semana (por groupKey de weeklyPromoGroupKey).
model HouseholdHiddenWeeklyPromo {
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  groupKey    String
  label       String
  createdAt   DateTime  @default(now())

  @@id([householdId, groupKey])
}

// Comercios/promos favoritos del hogar (priorizan en Hoy y Mi semana).
model HouseholdFavoriteWeeklyPromo {
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  groupKey    String
  label       String
  createdAt   DateTime  @default(now())

  @@id([householdId, groupKey])
}

// ============================================================
// CATEGORÍAS Y MEDIOS DE PAGO DEL HOGAR
// ============================================================

model Category {
  id          String   @id @default(cuid())
  // null = categoría global/default (seed), no exclusiva de un hogar
  householdId String?
  household   Household? @relation(fields: [householdId], references: [id])
  name        String   // Carnicería, Verdulería, Supermercado, Pollería, etc.
  icon        String?
  color       String?

  purchases   Purchase[]
  promotions  PromotionCategory[]
  recurringPayments RecurringPayment[]

  @@unique([householdId, name])
}

// Instancia de un medio de pago del catálogo en un hogar concreto.
// Los datos "de identidad" (banco, tipo, red) viven en la definición global;
// acá solo va lo específico de la instancia.
model PaymentMethod {
  id           String                  @id @default(cuid())
  householdId  String
  household    Household               @relation(fields: [householdId], references: [id])
  definitionId String
  definition   PaymentMethodDefinition @relation(fields: [definitionId], references: [id])
  ownerUserId  String?                 // de quién es la tarjeta/cuenta (para reportes por persona)
  owner        User?                   @relation("MethodOwner", fields: [ownerUserId], references: [id])

  nickname     String?                 // solo display ("la Visa de Mariano"); nunca se usa para matching
  lastFour     String?

  // Solo aplica a CREDIT_CARD: define en qué mes cae cada cuota
  closingDay   Int?                    // día de cierre del resumen (ej: 15)
  dueDay       Int?                    // día de vencimiento del resumen (ej: 10 del mes siguiente al cierre)

  purchases    Purchase[]
  recurringPayments RecurringPayment[]
  statementImports StatementImport[]

  @@unique([householdId, definitionId, lastFour])
  @@index([householdId])
}

// ============================================================
// PROMOCIONES (dato global, no específico de un hogar)
// ============================================================

model Promotion {
  id                 String             @id @default(cuid())
  entityId           String
  entity             Entity             @relation(fields: [entityId], references: [id])
  // Banco que patrocina el descuento en MODO (null = promo genérica MODO).
  sponsorBank        String?
  sponsorBanks       String[]           @default([]) // bancos adheridos en MODO (vacío = no restringe por banco)
  store              String?            // "ChangoMás", "Carrefour" — null = aplica a cualquier comercio
  paymentMethodType  PaymentMethodType? // restringe a un tipo de medio de pago si aplica
  cardNetwork        CardNetwork?       // restringe a una red (ej: "solo Visa"), null = cualquiera
  daysOfWeek         DayOfWeek[]        @default([]) // vacío = todos los días

  discountKind       DiscountKind       @default(PERCENTAGE_REFUND)
  discountLabel      String?            // ej. "25% de reintegro", "6 cuotas sin interés"
  discountPercentage Decimal            @db.Decimal(5, 2) // 0 para promos sin % (cuotas, etc.)
  discountCap        Decimal?           @db.Decimal(12, 2) // tope mensual en pesos, null = sin tope
  minPurchaseAmount  Decimal?           @db.Decimal(12, 2)
  imageUrl           String?            // logo/imagen del comercio (MODO primary_image)
  details            String[]           @default([]) // condiciones, locales adheridos, etc.
  provinces          String[]           @default([]) // vacío = aplica en todo el país
  storesAdherents    Boolean            @default(false) // requiere consultar locales adheridos
  paymentFlow        String?            // instore | online

  validFrom          DateTime?
  validTo            DateTime?

  source             PromotionSource    @default(MANUAL)
  sourceUrl          String?            // ej: https://www.modo.com.ar/promos
  // Clave de dedupe para promos scrapeadas: (fuente, id en la fuente).
  externalSource     String?            // "MODO"
  externalId         String?
  active             Boolean            @default(true)
  notes              String?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  purchases          Purchase[]
  categories         PromotionCategory[]
  capUsages          MonthlyCapUsage[]

  @@unique([externalSource, externalId])
  @@index([entityId, active])
}

// Estado del último sync de cada scraper (una fila por fuente).
model PromotionSync {
  source    String    @id // "MODO"
  lastRunAt DateTime?
  lastError String?
  imported  Int       @default(0)
  updated   Int       @default(0)
  deactivated Int     @default(0)
}

// Rubros/categorías a las que aplica una promo (ej: promo de combustible).
// Sin filas = la promo no declara rubro (matchea cualquier categoría).
model PromotionCategory {
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([promotionId, categoryId])
}

// ============================================================
// COMPRAS Y CUOTAS
// ============================================================

// Purchase = la transacción real. Guarda una "foto" del descuento aplicado
// (no solo el promotionId) para que el ahorro histórico no cambie si la
// promoción se edita o desactiva más adelante.
model Purchase {
  id              String    @id @default(cuid())
  // Id generado por el cliente para idempotencia en el sync offline:
  // reintentos del outbox no duplican compras.
  clientId        String?   @unique
  householdId     String
  household       Household @relation(fields: [householdId], references: [id])
  userId          String    // quién cargó/hizo la compra
  user            User      @relation(fields: [userId], references: [id])
  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  categoryId      String
  category        Category  @relation(fields: [categoryId], references: [id])

  store           String
  description     String?
  purchaseDate    DateTime

  // Montos
  grossAmount     Decimal   @db.Decimal(12, 2) // 100.000 (precio de lista, sin descuento)

  // Snapshot de la promo aplicada (si hubo)
  promotionId               String?
  promotion                 Promotion? @relation(fields: [promotionId], references: [id])
  discountPercentageApplied Decimal?  @db.Decimal(5, 2) // 25.00 (copiado al momento de la compra)
  discountCapApplied        Decimal?  @db.Decimal(12, 2) // tope restante disponible al momento de la compra
  discountLabelApplied      String?   // etiqueta manual (ej. "App YPF") cuando no hay promotionId

  discountAmount Decimal   @db.Decimal(12, 2) @default(0) // 20.000 → resultado ya con tope aplicado
  netAmount      Decimal   @db.Decimal(12, 2) // grossAmount - discountAmount = 80.000 (lo efectivamente pagado/financiado)

  // Currency of gross/net/discount/installment/allocation amounts. ARS reports use × exchangeRateToArs.
  currency            String    @default("ARS") // ARS | USD
  exchangeRateToArs   Decimal   @db.Decimal(12, 6) @default(1) // USD→ARS multiplier (1 for ARS)
  exchangeRateSource  String?   // e.g. dolarapi:tarjeta
  exchangeRateDate    DateTime? // calendar day the rate applies to

  installmentsCount Int    @default(1)

  // HOUSEHOLD = gasto compartido (default); PERSONAL = solo impacta al usuario que lo cargó.
  scope ExpenseScope @default(HOUSEHOLD)

  // Cómo se calculó el reparto (las filas en allocations son la fuente de verdad monetaria).
  splitMode SplitMode @default(EQUAL)

  // Snapshot de quién pagó al momento de la compra (dueño del medio, o quien cargó).
  paidByUserId String?
  paidBy       User?   @relation("PurchasePayer", fields: [paidByUserId], references: [id])

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Huella del consumo bancario cuando el gasto nace o se fusiona desde un resumen.
  // No es unique: una compra en cuotas puede vincularse a varias líneas a lo largo de los meses.
  statementFingerprint String?

  installments   Installment[]
  allocations    PurchaseAllocation[]
  recurringOccurrence RecurringOccurrence?
  statementImportLines StatementImportLine[]

  @@index([householdId, statementFingerprint])
  @@index([householdId, purchaseDate])
  @@index([categoryId])
  @@index([paidByUserId])
}

// Reparto del netAmount entre miembros del hogar (para dashboard "por persona").
model PurchaseAllocation {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  amount     Decimal  @db.Decimal(12, 2)

  @@unique([purchaseId, userId])
}

// Cada cuota es un "gasto" que impacta un mes específico.
// Para compras sin cuotas, installmentsCount = 1 y hay una sola Installment
// con dueDate = purchaseDate. Así el dashboard mensual siempre consulta
// esta tabla, sin distinguir contado vs. cuotas.
model Installment {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  // denormalizado para queries de dashboard sin joins pesados
  householdId String

  number      Int      // 1, 2, 3... N
  amount      Decimal  @db.Decimal(12, 2)
  dueDate     DateTime
  paid        Boolean  @default(false)
  paidDate    DateTime?

  @@index([householdId, dueDate])
  @@unique([purchaseId, number])
}

// ============================================================
// TOPE MENSUAL DE DESCUENTO POR BANCO
// ============================================================

// El tope de reintegro suele ser mensual y por banco/billetera (entity),
// compartido entre todas las promociones de esa entidad, no por transacción
// ni por promoción individual. Ej: si ya usaste $20.000 de tope con Santander
// este mes, una nueva compra con Santander no debería recibir más descuento,
// aunque sea otra promoción distinta de la misma entidad.
// Tope mensual de reintegro consumido, por promoción y por banco que paga.
// Cada promo tiene su propio tope, y cada banco adherido lo administra por
// separado: una promo MODO en ChangoMás pagada con Santander consume el tope
// de Santander; la misma promo pagada con BBVA usa el tope (independiente) de
// BBVA. `entityId` es la entidad del medio de pago usado (el banco), no la de
// la promo (que en MODO es la billetera).
model MonthlyCapUsage {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id])
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  entityId    String    // banco del medio de pago que consume el tope
  entity      Entity    @relation(fields: [entityId], references: [id])
  yearMonth   String    // formato "2026-07"
  usedAmount  Decimal   @db.Decimal(12, 2) @default(0)

  @@unique([householdId, promotionId, entityId, yearMonth])
  @@index([householdId, yearMonth])
}

// ============================================================
// IMPORTACIÓN DE RESÚMENES BANCARIOS
// ============================================================

model StatementImport {
  id              String                @id @default(cuid())
  householdId     String
  household       Household             @relation(fields: [householdId], references: [id])
  userId          String
  user            User                  @relation(fields: [userId], references: [id])
  paymentMethodId String?
  paymentMethod   PaymentMethod?        @relation(fields: [paymentMethodId], references: [id])
  fileName        String
  bankSource      String                // "Santander", "BBVA", etc.
  status          StatementImportStatus @default(PENDING)
  processedCount  Int                   @default(0)
  errorLog        String?
  importedAt      DateTime              @default(now())
  committedAt     DateTime?

  lines StatementImportLine[]

  @@index([householdId])
}

model StatementImportLine {
  id                   String                     @id @default(cuid())
  importId             String
  import               StatementImport            @relation(fields: [importId], references: [id], onDelete: Cascade)
  householdId          String
  fingerprint          String
  lineDate             DateTime
  store                String
  amount               Decimal                    @db.Decimal(12, 2)
  currency             String                     @default("ARS")
  installmentCurrent   Int?
  installmentTotal     Int?
  rawText              String
  suggestedSkip        Boolean                    @default(false)
  status               StatementImportLineStatus  @default(PENDING)
  matchedPurchaseId    String?
  matchedPurchase      Purchase?                  @relation(fields: [matchedPurchaseId], references: [id], onDelete: SetNull)
  amountResolution     StatementAmountResolution?
  categoryId           String?
  scope                ExpenseScope?
  splitMode            SplitMode?
  createdPurchaseId    String?

  @@unique([householdId, fingerprint])
  @@index([importId])
  @@index([householdId, status])
}

// ============================================================
// PAGOS RECURRENTES Y NOTIFICACIONES
// ============================================================

model RecurringPayment {
  id              String              @id @default(cuid())
  householdId     String
  household       Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User                @relation("RecurringCreator", fields: [createdByUserId], references: [id])
  name            String
  categoryId      String
  category        Category            @relation(fields: [categoryId], references: [id])
  paymentMethodId String?
  paymentMethod   PaymentMethod?      @relation(fields: [paymentMethodId], references: [id])
  scope           ExpenseScope        @default(HOUSEHOLD)
  cadence         RecurringCadence    @default(MONTHLY)
  dueDay          Int                 // 1–28
  amountType      RecurringAmountType
  amount          Decimal?            @db.Decimal(12, 2) // required when FIXED
  currency        String              @default("ARS") // ARS | USD
  exchangeRateToArs Decimal?          @db.Decimal(12, 6) // snapshot for FIXED USD display
  reminderDaysBefore Int              @default(3)
  active          Boolean             @default(true)
  nextDueDate     DateTime
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  amountHistory   RecurringAmountHistory[]
  occurrences     RecurringOccurrence[]

  @@index([householdId, active])
  @@index([nextDueDate])
}

model RecurringAmountHistory {
  id                 String           @id @default(cuid())
  recurringPaymentId String
  recurringPayment   RecurringPayment @relation(fields: [recurringPaymentId], references: [id], onDelete: Cascade)
  amount             Decimal          @db.Decimal(12, 2)
  effectiveFrom      DateTime
  createdByUserId    String
  createdBy          User             @relation(fields: [createdByUserId], references: [id])
  createdAt          DateTime         @default(now())

  @@index([recurringPaymentId, effectiveFrom])
}

model RecurringOccurrence {
  id                 String                    @id @default(cuid())
  recurringPaymentId String
  recurringPayment   RecurringPayment          @relation(fields: [recurringPaymentId], references: [id], onDelete: Cascade)
  dueDate            DateTime
  status             RecurringOccurrenceStatus @default(PENDING)
  amount             Decimal?                  @db.Decimal(12, 2)
  purchaseId         String?                   @unique
  purchase           Purchase?                 @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  reminderSentAt     DateTime?
  dueNotifiedAt      DateTime?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  @@unique([recurringPaymentId, dueDate])
  @@index([dueDate, status])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId String
  household   Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  body        String
  data        Json?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([userId, readAt, createdAt])
  @@index([householdId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId])
}

// Cached FX snapshots (e.g. dolarapi dólar tarjeta for USD→ARS).
model ExchangeRate {
  id           String   @id @default(cuid())
  date         DateTime // calendar day (UTC noon)
  fromCurrency String   // USD
  toCurrency   String   // ARS
  rate         Decimal  @db.Decimal(12, 6)
  source       String   // dolarapi:tarjeta
  fetchedAt    DateTime @default(now())

  @@unique([date, fromCurrency, toCurrency, source])
  @@index([fromCurrency, toCurrency, date])
}
